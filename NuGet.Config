<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Local feed populated by CI / local pack before solution restore.
         Required by tests/NetMediate.SourceGeneration.Tests which references
         NetMediate@0.0.1-internal to simulate the real NuGet package-reference scenario. -->
    <add key="local-packages" value="local-packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
