<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Local feed populated by the CI pre-build step (before dotnet restore net-mediate.slnx).
         Required by tests/NetMediate.SourceGeneration.Tests which references NetMediate with
         Version="*" to simulate the real NuGet package-reference scenario.
         The .gitkeep placeholder ensures this directory always exists so that NuGet never
         emits NU1301 on a fresh checkout (e.g. during Automatic Dependency Submission). -->
    <add key="local-packages" value="local-packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
